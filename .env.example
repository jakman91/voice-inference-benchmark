# Get your API key from app.baseten.co → Settings → API Keys
BASETEN_API_KEY=your_api_key_here

# After deploying each model with `truss push`, copy the endpoint URL
# from the model page (API → Endpoint) in the Baseten dashboard
QWEN_MODEL_URL=https://model-YOURMODELID.api.baseten.co/environments/production/sync/v1
MISTRAL_MODEL_URL=https://model-YOURMODELID.api.baseten.co/environments/production/sync/v1
LLAMA_MODEL_URL=https://model-YOURMODELID.api.baseten.co/environments/production/sync/v1
